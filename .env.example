# ─── Database ───────────────────────────────────────────────
# PostgreSQL connection string (local or hosted, e.g. Supabase / Neon)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/grc_platform?schema=public"

# ─── Clerk (Authentication / SSO) ───────────────────────────
# Get from https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Jira Integration ───────────────────────────────────────
# Jira Cloud base URL (e.g. https://your-org.atlassian.net)
JIRA_BASE_URL=https://your-org.atlassian.net
# Jira API token (https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=your_jira_api_token
# Jira account email associated with the token
JIRA_USER_EMAIL=your@email.com
# Jira project key where remediations will be created (e.g. SEC, GRC, RISK)
JIRA_PROJECT_KEY=GRC

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Internal API secret for server-to-server calls
INTERNAL_API_SECRET=change_me_to_a_long_random_string
